# API Keys para ReliableAI local
# Copia este archivo a .env y rellena con tus claves reales

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT)
OPENAI_API_KEY=sk-...

# Google (Gemini)
GOOGLE_API_KEY=AIza...

# xAI (Grok)
XAI_API_KEY=xai-...

# Qwen (Alibaba DashScope)
QWEN_API_KEY=sk-...

# Database
DB_PATH=data/data.db

# Session
SESSION_SECRET=your_secret_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (Resend)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=onboarding@resend.dev
SMTP_PASS=your_resend_api_key

# Node environment
NODE_ENV=development
PORT=3000
