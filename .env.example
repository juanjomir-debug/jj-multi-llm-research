# ── AI Provider Keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
XAI_API_KEY=xai-...
MOONSHOT_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...
QWEN_API_KEY=sk-...
ZHIPU_API_KEY=...

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_64_random_chars

# ── Stripe (payment gateway) ─────────────────────────────────────────────────
# 1. Create account at https://dashboard.stripe.com
# 2. Copy Secret Key from Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
# 3. Create Webhook in Developers → Webhooks → Add endpoint
#    URL: https://your-domain.com/api/billing/webhook
#    Events: checkout.session.completed, customer.subscription.deleted,
#            customer.subscription.updated, invoice.payment_succeeded, invoice.payment_failed
#    Copy the Signing Secret here:
STRIPE_WEBHOOK_SECRET=whsec_...
# 4. Create 3 Products in Stripe → Products (monthly recurring prices):
#    - Starter: €9.99/month
#    - Pro:     €29.99/month
#    - Business: €99.00/month
# 5. Configure price IDs by calling (replace YOUR_ADMIN_TOKEN, price_xxx with real IDs):
#    curl -X POST http://localhost:3000/api/admin/billing/plans \
#      -H "Content-Type: application/json" \
#      -d '{"token":"YOUR_ADMIN_TOKEN","plans":[{"id":"starter","stripe_price_id":"price_xxx"},{"id":"pro","stripe_price_id":"price_yyy"},{"id":"business","stripe_price_id":"price_zzz"}]}'

# ── App URL (for Stripe redirects) ───────────────────────────────────────────
APP_URL=https://your-app.railway.app

# ── Admin token (for /api/admin/* endpoints) ─────────────────────────────────
ADMIN_TOKEN=change_me_to_something_secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── WordPress Blog (blog.reliableai.net) ──────────────────────────────────────
# 1. Go to WordPress Admin → Users → Your Profile
# 2. Scroll to "Application Passwords"
# 3. Create new with name "ReliableAI Publisher"
# 4. Copy the generated password here:
WP_URL=https://blog.reliableai.net
WP_USER=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Twitter Bot (for publishing threads) ──────────────────────────────────────
# Opción 1: API oficial (recomendado - más confiable)
# Obtener en: https://developer.twitter.com/en/portal/dashboard
# 1. Crea un proyecto y una app
# 2. En "Keys and tokens" genera API Key & Secret
# 3. Genera Access Token & Secret con permisos "Read and Write"
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# Opción 2: Playwright (fallback - requiere cookies)
TWITTER_PASSWORD=your_twitter_password_here
