require 'base64'

default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  lane :deploy do
    # Debug: Print current directory and check paths
    puts "=== Fastlane Debug Info ==="
    puts "Current directory: #{Dir.pwd}"
    puts "Checking for ios/App/App.xcodeproj..."
    if File.exist?("ios/App/App.xcodeproj")
      puts "✓ Found ios/App/App.xcodeproj"
    else
      puts "✗ NOT FOUND: ios/App/App.xcodeproj"
      puts "Directory contents:"
      system("ls -la")
      puts "ios/ contents:"
      system("ls -la ios/") if Dir.exist?("ios")
      puts "ios/App/ contents:"
      system("ls -la ios/App/") if Dir.exist?("ios/App")
    end
    puts "=== End Debug Info ==="

    # App Store Connect API key (avoids 2FA issues)
    api_key = app_store_connect_api_key(
      key_id:      ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:   ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_BASE64"]),
      in_house:    false
    )

    # Auto-increment build number using GitHub run number
    build_num = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    
    # Configure code signing before build
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "C59QGKA8BH",
      bundle_identifier: "net.reliableai.app",
      code_sign_identity: "Apple Distribution",
      profile_name: "ReliableAI App Store",
      path: "ios/App/App.xcodeproj"
    )
    
    increment_build_number(
      build_number: build_num,
      xcodeproj:   "ios/App/App.xcodeproj"
    )

    # Build
    build_app(
      scheme:        "App",
      workspace:     "ios/App/App.xcworkspace",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "net.reliableai.app" => "ReliableAI App Store"
        },
        teamID: "C59QGKA8BH"
      },
      xcargs: "DEVELOPMENT_TEAM=C59QGKA8BH CODE_SIGN_STYLE=Manual",
      output_directory: "./",
      output_name:      "ReliableAI.ipa"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key:                          api_key,
      skip_waiting_for_build_processing: true,
      changelog:                        "Automatic build from GitHub Actions"
    )
  end

  desc "Local build only (no upload) — for testing the CI config"
  lane :build_only do
    build_app(
      scheme:        "App",
      workspace:     "ios/App/App.xcworkspace",
      configuration: "Release",
      export_method: "app-store"
    )
  end

end
